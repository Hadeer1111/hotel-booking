# app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# api — browser calls this URL. Options:
# (a) NEXT_PUBLIC_API_URL — baked in at `next build` (change requires rebuild).
# (b) Omit NEXT_PUBLIC_API_URL in production and set API_BACKEND_ORIGIN (below): the app
#     uses same-origin paths `/v1/...` → proxy to API_BACKEND_ORIGIN; change origin + restart only.
# NEXT_PUBLIC_API_URL=https://YOUR-API-SERVICE.up.railway.app/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
INTERNAL_API_URL=http://localhost:4000/v1

# Server-only (Next reads this when `next dev` / `next start` loads next.config).
# Enables same-origin `/v1/*` → proxy to `<origin>/v1/*`. Omit path and trailing slash.
# Examples:
#   Railway web service (Nest deployed separately): https://your-api.up.railway.app
#   Local prod smoke (`next build && next start`): http://localhost:4000
API_BACKEND_ORIGIN=

# payments — must match API PAYMENTS_PROVIDER (mock | stripe). Stripe needs pk_test_/pk_live_ pair with API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_PAYMENTS_PROVIDER=mock
