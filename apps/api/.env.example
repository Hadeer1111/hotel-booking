# app
NODE_ENV=development
PORT=4000

# database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_booking?schema=public

# auth
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# payments
PAYMENTS_PROVIDER=mock
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd

# security
CORS_ORIGIN=http://localhost:3000
THROTTLE_TTL=60
THROTTLE_LIMIT=20

# observability
LOG_LEVEL=debug
