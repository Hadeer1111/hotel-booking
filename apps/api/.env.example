# app
NODE_ENV=development
PORT=4000

# database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_booking?schema=public

# auth
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# payments — mock needs no Stripe keys. For Stripe locally:
#   1. PAYMENTS_PROVIDER=stripe + keys below (test mode).
#   2. Install Stripe CLI; run:
#        stripe listen --forward-to localhost:4000/v1/payments/webhook
#      Paste the printed webhook signing secret into STRIPE_WEBHOOK_SECRET (starts with whsec_).
#   3. apps/web/.env.local: NEXT_PUBLIC_PAYMENTS_PROVIDER=stripe + NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
PAYMENTS_PROVIDER=mock
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd

# security — comma-separated origins allowed by CORS (production web URL must be listed):
# CORS_ORIGIN=http://localhost:3000,https://YOUR-WEB-SERVICE.up.railway.app
CORS_ORIGIN=http://localhost:3000
THROTTLE_TTL=60
THROTTLE_LIMIT=20

# observability
LOG_LEVEL=debug
