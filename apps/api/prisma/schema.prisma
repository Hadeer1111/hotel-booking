// Hotel booking system — Prisma schema.
// See README "Design decisions" for why Room is modelled as a physical unit
// and availability is derived from overlapping bookings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CUSTOMER
}

enum HotelStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedHotels Hotel[]   @relation("HotelManager")
  bookings      Booking[]

  @@index([role])
}

model Hotel {
  id        String      @id @default(uuid())
  name      String
  city      String
  address   String
  stars     Int
  status    HotelStatus @default(ACTIVE)
  managerId String?
  manager   User?       @relation("HotelManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  roomTypes RoomType[]

  @@index([city])
  @@index([name])
  @@index([managerId])
  @@index([status])
}

model RoomType {
  id                 String   @id @default(uuid())
  hotelId            String
  hotel              Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  capacity           Int
  basePricePerNight  Decimal  @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rooms Room[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model Room {
  id         String   @id @default(uuid())
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  roomNumber String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bookings Booking[]

  @@unique([roomTypeId, roomNumber])
  @@index([roomTypeId])
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  roomId     String
  room       Room          @relation(fields: [roomId], references: [id], onDelete: Restrict)
  checkIn    DateTime      @db.Timestamptz(3)
  checkOut   DateTime      @db.Timestamptz(3)
  guestCount Int
  totalPrice Decimal       @db.Decimal(10, 2)
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  payment Payment?

  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@index([checkIn, checkOut])
}

model Payment {
  id                    String        @id @default(uuid())
  bookingId             String        @unique
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider              String
  providerPaymentId     String?
  providerEventLastSeen String?
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @db.Char(3)
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  events PaymentEvent[]

  @@index([providerPaymentId])
  @@index([status])
}

model PaymentEvent {
  id              String   @id @default(uuid())
  paymentId       String
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  providerEventId String   @unique
  type            String
  payload         Json
  createdAt       DateTime @default(now())

  @@index([paymentId])
}
