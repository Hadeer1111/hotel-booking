# Root-level env example. Each app also has its own .env.example.
# Copy to .env and adjust for local development.
#
# Web-only (same-origin API proxy): see apps/web/.env.example → API_BACKEND_ORIGIN

# database (used by docker-compose and Prisma)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hotel_booking
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_booking?schema=public
